    },
    {
      "type": "text",
      "tag": "p",
      "text": "Cyber Imposter"
    },
    {
      "type": "text",
      "tag": "p",
      "text": "A multi-player mobile strategy game. Players' goal is to cover the AI teammate and identify the AI opponent."
    },
    {
      "type": "image",
      "src": "https://cdn.prod.website-files.com/63a0d533a7afeac89489815e/66a2ac26af28d71faea660fc_Subtract%20white.png",
      "alt": ""
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Overview"
    },
    {
      "type": "listItem",
      "tag": "li",
      "text": "Timeline: Sep 2024 - Feb 2025"
    },
    {
      "type": "listItem",
      "tag": "li",
      "text": "Company: Starward Game Studios"
    },
    {
      "type": "listItem",
      "tag": "li",
      "text": "Role: UX Designer Intern"
    },
    {
      "type": "image",
      "src": "https://cdn.prod.website-files.com/63a0d533a7afeac89489815e/66a2abbe39d4e32449faa33d_Subtract%20black.png",
      "alt": ""
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Prototypes"
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Enter lobby and join a room"
    },
    {
      "type": "text",
      "tag": "p",
      "text": "Users can join or create a room to start the game."
    },
    {
      "type": "text",
      "tag": "p",
      "text": "Rooms can be filtered by language preference, genre preference, and room size."
    },
    {
      "type": "image",
      "src": "https://cdn.prod.website-files.com/63a0d533a7afeac89489815e/670ac6d9e0143bf29f7beafc_Screen%20Shot%202024-10-12%20at%202.54.42%20PM.png",
      "alt": ""
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Teams take turns to ask, answer, and vote, with the goal of finding the hidden non-human player"
    },
    {
      "type": "text",
      "tag": "p",
      "text": "Each team is made up of one AI player (bot) and three real players."
    },
    {
      "type": "text",
      "tag": "p",
      "text": "The teams take turns asking the opposing team a question."
    },
    {
      "type": "text",
      "tag": "p",
      "text": "Based on the responses given, the objective is to figure out which answer came from the AI and which came from the human players."
    },
    {
      "type": "heading",
      "level": 1,
      "text": "Ask Phase"
    },
    {
      "type": "image",
      "src": "https://cdn.prod.website-files.com/63a0d533a7afeac89489815e/670acb3c1420c81b83150fbf_Asking.png",
      "alt": ""
    },
