---
/**
 * PolaroidCard — lime-green Polaroid frame, 667 × 791 px
 *
 * One full-height SVG paints the lime frame + footer background.
 * The lens rectangle is cut out via an SVG mask (genuinely transparent).
 * The caption HTML is overlaid at the bottom using position: absolute.
 */
interface Props {
  caption?: string;
  class?: string;
}

const { caption = "You are looking for", class: className } = Astro.props;

const W = 667, H = 791;
const PAD_SIDE = 48;
const PAD_TOP  = 48;
const FOOTER_H = 164;
const lensX = PAD_SIDE;
const lensY = PAD_TOP;
const lensW = W - PAD_SIDE * 2;      // 571
const lensH = H - PAD_TOP - FOOTER_H; // 635
---

<div
  class:list={["polaroid-wrap", className]}
  style="position:relative;width:667px;height:791px;flex-shrink:0;"
>

  <!--
    Full-height SVG: lime fills everything EXCEPT the lens window.
    mask: white = paint lime, black = transparent hole.
  -->
  <svg
    class="polaroid-svg"
    width={W}
    height={H}
    viewBox={`0 0 ${W} ${H}`}
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    style="display:block;position:absolute;top:0;left:0;"
  >
    <defs>
      <mask id="frame-mask">
        <!-- white = show lime across the full card -->
        <rect width={W} height={H} fill="white" />
        <!-- black = punch out the lens -->
        <rect x={lensX} y={lensY} width={lensW} height={lensH} rx="4" fill="black" />
      </mask>
    </defs>
    <rect width={W} height={H} fill="#b8d432" mask="url(#frame-mask)" />
  </svg>

  <!-- Caption overlay — sits over the lime footer area -->
  <footer class="polaroid-footer">
    <span class="polaroid-caption">{caption}</span>

    <div class="polaroid-actions" aria-label="Interaction icons">
      <!-- Heart outline -->
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                 a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>

      <!-- Thumbs-up outline -->
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0
                 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/>
        <path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
      </svg>

      <!-- Retweet / share outline -->
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="17 1 21 5 17 9"/>
        <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
        <polyline points="7 23 3 19 7 15"/>
        <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
      </svg>
    </div>
  </footer>

</div>

<style>
  /* ── Wrapper: contains SVG + absolutely-positioned footer ────────── */
  .polaroid-wrap {
    flex-shrink: 0;
    height: 791px;
    position: relative;
    width: 667px;
  }

  .polaroid-svg {
    display: block;
    left: 0;
    position: absolute;
    top: 0;
  }

  /* ── Caption bar — overlaid on the lime footer strip ─────────────── */
  .polaroid-footer {
    align-items: center;
    bottom: 60px;
    color: #111;
    display: flex;
    font-size: 28px;
    height: 108px;
    justify-content: space-between;
    left: 0;
    letter-spacing: -0.01em;
    padding: 0 50px;
    position: absolute;
    right: 0;
  }

  .polaroid-caption {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 300;
  }

  .polaroid-actions {
    align-items: center;
    display: flex;
    gap: 18px;
  }

  .polaroid-actions svg {
    cursor: pointer;
    flex-shrink: 0;
    opacity: 0.75;
    transition: opacity 200ms ease;
  }

  .polaroid-actions svg:hover {
    opacity: 1;
  }
</style>
